<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_background">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:title="Aggiungi Nuovo Pasto"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <!-- STEP 1: NOME DEL PASTO -->
        <include
            android:id="@+id/stepName"
            layout="@layout/item_add_meal_step" />

        <!-- STEP 2: TIPO DI PASTO (Sbloccato dopo il Nome) -->
        <include
            android:id="@+id/stepType"
            layout="@layout/item_add_meal_step"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp" />

        <!-- STEP 3: DATA E ORA (Sbloccato dopo il Tipo) -->
        <include
            android:id="@+id/stepDate"
            layout="@layout/item_add_meal_step"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp" />

        <!-- STEP 4: CALORIE (Opzionale) -->
        <include
            android:id="@+id/stepKcal"
            layout="@layout/item_add_meal_step"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveMeal"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="40dp"
            android:text="Salva nel Diario"
            android:enabled="false"
            app:cornerRadius="16dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>